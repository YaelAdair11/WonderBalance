<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Saludo -->
        <TextView
            android:id="@+id/txt_saludo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Hola, Usuario"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#2C2C2A"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"/>

        <!-- Tarjeta Balance General -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/tarjeta_balance"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#7F77DD"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/txt_saludo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <TextView
                    android:id="@+id/txt_etiqueta_balance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Balance General"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/txt_balance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textColor="#FFFFFF"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@id/txt_etiqueta_balance"
                    app:layout_constraintStart_toStartOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Botones de acción rápida -->
        <LinearLayout
            android:id="@+id/contenedor_acciones"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/tarjeta_balance"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_nueva_transaccion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_input_add"
                app:backgroundTint="#7F77DD"
                app:tint="@color/white"
                android:layout_marginEnd="24dp"/>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_ver_historial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_menu_recent_history"
                app:backgroundTint="#5DCAA5"
                app:tint="@color/white"
                android:layout_marginEnd="24dp"/>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_analitica"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:backgroundTint="#EF9F27"
                app:tint="@color/white"/>

        </LinearLayout>

        <!-- Etiquetas de acciones -->
        <LinearLayout
            android:id="@+id/contenedor_etiquetas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/contenedor_acciones"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nueva"
                android:textSize="11sp"
                android:gravity="center"
                android:textColor="#888780"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Historial"
                android:textSize="11sp"
                android:gravity="center"
                android:textColor="#888780"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Analítica"
                android:textSize="11sp"
                android:gravity="center"
                android:textColor="#888780"/>

        </LinearLayout>

        <!-- Título últimas transacciones -->
        <TextView
            android:id="@+id/txt_ultimas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Últimas Transacciones"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#2C2C2A"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/contenedor_etiquetas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Lista de últimas transacciones -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/lista_transacciones"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/txt_ultimas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Mensaje sin transacciones -->
        <TextView
            android:id="@+id/txt_sin_transacciones"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Aún no tienes transacciones registradas"
            android:textColor="#888780"
            android:gravity="center"
            android:layout_marginTop="24dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/txt_ultimas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>